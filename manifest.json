{
  "manifest_version": 3,
  "name": "cek",
  "version": "1.0.0",
  "description": "Quiet co-pilot for ChatGPT and Claude — prompt history and context tracking.",
  "permissions": ["storage", "alarms", "activeTab", "tabs", "downloads"],
  "host_permissions": [
    "https://api.groq.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_title": "cek",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/claude.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["src/content/chatgpt.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "options_ui": {
    "page": "src/settings/settings.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/platform-icons/*.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      }
    }
  }
}
